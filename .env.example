# Database Configuration
DATABASE_URL=postgresql://postgres.xxxxx:your_password@aws-0-region.pooler.supabase.com:6543/postgres
PGHOST=db.xxxxx.supabase.co
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_supabase_password
PGDATABASE=postgres

# Session Management
SESSION_SECRET=your_32_character_random_session_secret_here

# Application Configuration
NODE_ENV=development
PORT=5000

# Optional: Frontend Environment Variables (prefix with VITE_)
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=IT Helpdesk Portal

# Optional: Logging
LOG_LEVEL=debug

# Email Configuration (for ticket notifications)
SMTP_HOST=mail.cybaemtech.in
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@cybaemtech.in
SMTP_PASS=your_email_password_here
EMAIL_FROM="ITSM Support" <noreply@cybaemtech.in>
APP_URL=https://cybaemtech.in/itsm_app